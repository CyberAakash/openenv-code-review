# =============================================================
# Code Review OpenEnv — Environment Variables
# =============================================================

# --- Required by hackathon spec (used by inference.py) ---

# LLM API endpoint (OpenAI-compatible)
API_BASE_URL=https://api.openai.com/v1

# Model identifier
MODEL_NAME=gpt-4o-mini

# API key for the LLM provider
HF_TOKEN=your-api-key-here

# --- Optional ---

# Code Review environment server URL (defaults to HF Space)
# ENV_URL=https://CyberAakash-code-review.hf.space

# Comma-separated list of task IDs to run (defaults to all 15)
# TASKS=easy_1,easy_2,easy_3,easy_4,easy_5,medium_1,medium_2,medium_3,medium_4,medium_5,hard_1,hard_2,hard_3,hard_4,hard_5
